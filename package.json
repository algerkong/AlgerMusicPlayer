{
  "name": "LYMusicPlayer",
  "version": "5.1.0",
  "description": "LYMusic Player",
  "author": "落叶🍂 (@LuoYe17)",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/LuoYe17/AlgerMusicPlayer",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write ./src",
    "lint": "oxlint ./src --fix && npm run lint:i18n",
    "lint:i18n": "bun scripts/check_i18n.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:web": "vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "fix-sandbox": "node scripts/fix-sandbox.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "lint:ox": "oxlint ./src"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,mjs,cjs}": [
      "oxlint --fix"
    ],
    "*.{ts,tsx,vue,js,css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@httptoolkit/dbus-native": "^0.1.5",
    "@lucide/vue": "^1.24.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3",
    "file-type": "^22.0.1",
    "flac-tagger": "^2.0.0",
    "font-list": "^2.1.0",
    "form-data": "^4.0.6",
    "ly-music-source": "git+https://github.com/LuoYe17/ly-music-source.git#v0.1.23",
    "mpris-service": "^2.1.2",
    "music-metadata": "^11.14.0",
    "node-id3": "^0.2.9",
    "node-machine-id": "^1.1.12",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "shadcn-vue": "^2.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^24.0.0",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/compiler-sfc": "^3.5.40",
    "@vue/runtime-core": "^3.5.40",
    "@vueuse/core": "^14.3.0",
    "@vueuse/electron": "^14.3.0",
    "animate.css": "^4.1.1",
    "autoprefixer": "^10.5.4",
    "axios": "^1.18.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.10.6",
    "howler": "^2.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lodash": "^4.18.1",
    "marked": "^18.0.6",
    "naive-ui": "^2.44.1",
    "oxlint": "^1.74.0",
    "pinia": "^4.0.2",
    "pinyin-match": "^1.2.10",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "remixicon": "^4.9.1",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.19",
    "tinycolor2": "^1.6.0",
    "tunajs": "^1.1.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.6",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vue-devtools": "8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vue-tsc": "^3.3.7"
  },
  "build": {
    "appId": "com.luoye.music",
    "productName": "LYMusicPlayer",
    "publish": [
      {
        "provider": "github",
        "owner": "LuoYe17",
        "repo": "AlgerMusicPlayer"
      }
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Audio",
      "maintainer": "落叶🍂 (@LuoYe17)"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LYMusic",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "LYMusic"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "optionalDependencies": {
    "jsbi": "^4.3.2",
    "x11": "^2.3.0"
  },
  "allowScripts": {
    "electron@43.1.1": true,
    "ly-music-source": true,
    "github:LuoYe17/ly-music-source#dbaf654723662f66ee9dd557238dcd2b84be9228": true,
    "github:LuoYe17/ly-music-source#826df12a86a6141e6321694d628ec2d352daa52e": true
  }
}
